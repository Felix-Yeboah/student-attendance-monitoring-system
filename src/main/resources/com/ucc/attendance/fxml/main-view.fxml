<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ucc.attendance.controller.MainController"
            styleClass="root">

    <top>
        <VBox styleClass="app-header">

            <MenuBar>
                <menus>
                    <Menu text="File">
                        <items>
                            <MenuItem text="Refresh" onAction="#handleRefresh" />
                            <MenuItem text="Exit" onAction="#handleExit" />
                        </items>
                    </Menu>

                    <Menu text="Help">
                        <items>
                            <MenuItem text="Refresh Dashboard" onAction="#handleRefreshDashboard" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="brand-bar">
                <VBox spacing="3.0">
                    <Label text="Student Attendance Monitoring System"
                           styleClass="brand-title" />

                    <Label text="Manage students, courses, users, attendance registers, and reports"
                           styleClass="brand-subtitle" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER_RIGHT" spacing="4.0" styleClass="logged-user-box">
                    <Label fx:id="loggedInUserLabel"
                           text="User"
                           styleClass="logged-user-name" />

                    <Label fx:id="loggedInRoleLabel"
                           text="ROLE"
                           styleClass="logged-user-role" />

                    <HBox alignment="CENTER_RIGHT" spacing="10.0">
                        <Button text="Refresh"
                                mnemonicParsing="false"
                                onAction="#handleRefresh"
                                styleClass="secondary-button" />

                        <Button text="Logout"
                                mnemonicParsing="false"
                                onAction="#handleLogout"
                                styleClass="danger-button" />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="main-tab-pane">

            <!-- =========================
                 DASHBOARD TAB
                 ========================= -->
            <Tab text="Dashboard">
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <content>
                        <VBox spacing="22.0" styleClass="page-container">
                            <padding>
                                <Insets top="24.0" right="28.0" bottom="28.0" left="28.0" />
                            </padding>

                            <VBox spacing="6.0">
                                <Label text="Dashboard Overview"
                                       styleClass="page-title" />

                                <Label text="A quick summary of students, courses, and today’s attendance activity."
                                       styleClass="page-subtitle" />
                            </VBox>

                            <FlowPane hgap="18.0" vgap="18.0" prefWrapLength="980.0">

                                <VBox spacing="8.0" styleClass="stat-card, students-stat-card">
                                    <Label text="Total Students" styleClass="stat-title" />
                                    <Label fx:id="totalStudentsLabel" text="0" styleClass="stat-value" />
                                    <Label text="Registered active learners" styleClass="stat-caption" />
                                </VBox>

                                <VBox spacing="8.0" styleClass="stat-card, courses-stat-card">
                                    <Label text="Total Courses" styleClass="stat-title" />
                                    <Label fx:id="totalCoursesLabel" text="0" styleClass="stat-value" />
                                    <Label text="Available academic modules" styleClass="stat-caption" />
                                </VBox>

                                <VBox spacing="8.0" styleClass="stat-card, present-stat-card">
                                    <Label text="Today Present" styleClass="stat-title" />
                                    <Label fx:id="todayPresentLabel" text="0" styleClass="stat-value" />
                                    <Label text="Marked present today" styleClass="stat-caption" />
                                </VBox>

                                <VBox spacing="8.0" styleClass="stat-card, late-stat-card">
                                    <Label text="Today Late" styleClass="stat-title" />
                                    <Label fx:id="todayLateLabel" text="0" styleClass="stat-value" />
                                    <Label text="Arrived late today" styleClass="stat-caption" />
                                </VBox>

                                <VBox spacing="8.0" styleClass="stat-card, absent-stat-card">
                                    <Label text="Today Absent" styleClass="stat-title" />
                                    <Label fx:id="todayAbsentLabel" text="0" styleClass="stat-value" />
                                    <Label text="Marked absent today" styleClass="stat-caption" />
                                </VBox>

                                <VBox spacing="8.0" styleClass="stat-card, marked-stat-card">
                                    <Label text="Marked Today" styleClass="stat-title" />
                                    <Label fx:id="todayMarkedLabel" text="0" styleClass="stat-value" />
                                    <Label text="Total register entries" styleClass="stat-caption" />
                                </VBox>

                                <VBox spacing="8.0" styleClass="stat-card, rate-stat-card">
                                    <Label text="Attendance Rate" styleClass="stat-title" />
                                    <Label fx:id="todayAttendanceRateLabel" text="0.0%" styleClass="stat-value" />
                                    <Label text="Present and late percentage" styleClass="stat-caption" />
                                </VBox>

                                <VBox spacing="8.0" styleClass="stat-card, alert-stat-card">
                                    <Label text="Status" styleClass="stat-title" />
                                    <Label fx:id="todayRiskLabel" text="No register" styleClass="stat-value-small" />
                                    <Label text="Today’s attendance condition" styleClass="stat-caption" />
                                </VBox>

                            </FlowPane>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <!-- =========================
                 STUDENTS TAB
                 ========================= -->
            <Tab text="Students">
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <content>
                        <VBox spacing="20.0" styleClass="page-container">
                            <padding>
                                <Insets top="24.0" right="28.0" bottom="28.0" left="28.0" />
                            </padding>

                            <VBox spacing="6.0">
                                <Label text="Student Management"
                                       styleClass="page-title" />

                                <Label text="Create, update, search, and manage student records."
                                       styleClass="page-subtitle" />
                            </VBox>

                            <GridPane hgap="14.0" vgap="12.0" styleClass="form-card">
                                <padding>
                                    <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                                </padding>

                                <Label text="Student Number" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <TextField fx:id="studentNumberField"
                                           promptText="Example: STU001"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="1" />

                                <Label text="First Name" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <TextField fx:id="studentFirstNameField"
                                           promptText="First name"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="1" />

                                <Label text="Last Name" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <TextField fx:id="studentLastNameField"
                                           promptText="Last name"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="1" />

                                <Label text="Email" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <TextField fx:id="studentEmailField"
                                           promptText="student@example.com"
                                           GridPane.rowIndex="3"
                                           GridPane.columnIndex="1" />

                                <Label text="Programme" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                                <TextField fx:id="studentProgrammeField"
                                           promptText="Example: MSc Information Technology"
                                           GridPane.rowIndex="4"
                                           GridPane.columnIndex="1" />

                                <Label text="Gender" GridPane.rowIndex="5" GridPane.columnIndex="0" />
                                <ComboBox fx:id="studentGenderComboBox"
                                          promptText="Select gender"
                                          prefWidth="260.0"
                                          GridPane.rowIndex="5"
                                          GridPane.columnIndex="1" />

                                <HBox spacing="10.0" GridPane.rowIndex="6" GridPane.columnIndex="1">
                                    <Button fx:id="studentSaveButton"
                                            text="Save Student"
                                            onAction="#handleSaveStudent"
                                            styleClass="primary-button" />

                                    <Button text="Clear"
                                            onAction="#handleClearStudentForm"
                                            styleClass="secondary-button" />

                                    <Button text="Delete"
                                            onAction="#handleDeleteStudent"
                                            styleClass="danger-button" />
                                </HBox>
                            </GridPane>

                            <HBox alignment="CENTER_LEFT" spacing="12.0">
                                <Label text="Search Students:" />
                                <TextField fx:id="studentSearchField"
                                           promptText="Search by name, student number, email, or programme"
                                           HBox.hgrow="ALWAYS" />
                            </HBox>

                            <TableView fx:id="studentTable" prefHeight="360.0">
                                <columns>
                                    <TableColumn fx:id="studentIdColumn" text="ID" prefWidth="60.0" />
                                    <TableColumn fx:id="studentNumberColumn" text="Student No." prefWidth="130.0" />
                                    <TableColumn fx:id="studentNameColumn" text="Full Name" prefWidth="190.0" />
                                    <TableColumn fx:id="studentEmailColumn" text="Email" prefWidth="220.0" />
                                    <TableColumn fx:id="studentProgrammeColumn" text="Programme" prefWidth="230.0" />
                                    <TableColumn fx:id="studentGenderColumn" text="Gender" prefWidth="130.0" />
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <!-- =========================
                 COURSES TAB
                 ========================= -->
            <Tab text="Courses">
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <content>
                        <VBox spacing="20.0" styleClass="page-container">
                            <padding>
                                <Insets top="24.0" right="28.0" bottom="28.0" left="28.0" />
                            </padding>

                            <VBox spacing="6.0">
                                <Label text="Course Management"
                                       styleClass="page-title" />

                                <Label text="Create courses and assign them to lecturer user accounts."
                                       styleClass="page-subtitle" />
                            </VBox>

                            <GridPane hgap="14.0" vgap="12.0" styleClass="form-card">
                                <padding>
                                    <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                                </padding>

                                <Label text="Course Code" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <TextField fx:id="courseCodeField"
                                           promptText="Example: INF811D"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="1" />

                                <Label text="Course Title" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <TextField fx:id="courseTitleField"
                                           promptText="Example: Object Oriented Programming"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="1" />

                                <Label text="Lecturer Username" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <TextField fx:id="courseLecturerField"
                                           promptText="Example: lecturer"
                                           GridPane.rowIndex="2"
                                           GridPane.columnIndex="1" />

                                <Label text="Semester" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <TextField fx:id="courseSemesterField"
                                           promptText="Example: Semester 1"
                                           GridPane.rowIndex="3"
                                           GridPane.columnIndex="1" />

                                <HBox spacing="10.0" GridPane.rowIndex="4" GridPane.columnIndex="1">
                                    <Button fx:id="courseSaveButton"
                                            text="Save Course"
                                            onAction="#handleSaveCourse"
                                            styleClass="primary-button" />

                                    <Button text="Clear"
                                            onAction="#handleClearCourseForm"
                                            styleClass="secondary-button" />

                                    <Button text="Delete"
                                            onAction="#handleDeleteCourse"
                                            styleClass="danger-button" />
                                </HBox>
                            </GridPane>

                            <TableView fx:id="courseTable" prefHeight="420.0">
                                <columns>
                                    <TableColumn fx:id="courseIdColumn" text="ID" prefWidth="60.0" />
                                    <TableColumn fx:id="courseCodeColumn" text="Course Code" prefWidth="140.0" />
                                    <TableColumn fx:id="courseTitleColumn" text="Course Title" prefWidth="280.0" />
                                    <TableColumn fx:id="courseLecturerColumn" text="Lecturer" prefWidth="220.0" />
                                    <TableColumn fx:id="courseSemesterColumn" text="Semester" prefWidth="150.0" />
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <!-- =========================
                 USERS TAB
                 ========================= -->
            <Tab fx:id="usersTab" text="Users">
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <content>
                        <VBox spacing="20.0" styleClass="page-container">
                            <padding>
                                <Insets top="24.0" right="28.0" bottom="28.0" left="28.0" />
                            </padding>

                            <VBox spacing="6.0">
                                <Label text="User Management"
                                       styleClass="page-title" />

                                <Label text="Create administrator and lecturer accounts, and activate or deactivate users."
                                       styleClass="page-subtitle" />
                            </VBox>

                            <GridPane hgap="14.0" vgap="12.0" styleClass="form-card">
                                <padding>
                                    <Insets top="18.0" right="18.0" bottom="18.0" left="18.0" />
                                </padding>

                                <Label text="Full Name" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                                <TextField fx:id="userFullNameField"
                                           promptText="Example: Ama Mensah"
                                           GridPane.rowIndex="0"
                                           GridPane.columnIndex="1" />

                                <Label text="Username" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                                <TextField fx:id="userUsernameField"
                                           promptText="Example: amensah"
                                           GridPane.rowIndex="1"
                                           GridPane.columnIndex="1" />

                                <Label text="Temporary Password" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                                <PasswordField fx:id="userPasswordField"
                                               promptText="At least 8 characters"
                                               GridPane.rowIndex="2"
                                               GridPane.columnIndex="1" />

                                <Label text="Role" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                                <ComboBox fx:id="userRoleComboBox"
                                          promptText="Select role"
                                          prefWidth="260.0"
                                          GridPane.rowIndex="3"
                                          GridPane.columnIndex="1" />

                                <HBox spacing="10.0" GridPane.rowIndex="4" GridPane.columnIndex="1">
                                    <Button text="Create User"
                                            onAction="#handleCreateUser"
                                            styleClass="primary-button" />

                                    <Button text="Clear"
                                            onAction="#handleClearUserForm"
                                            styleClass="secondary-button" />

                                    <Button text="Activate"
                                            onAction="#handleActivateUser"
                                            styleClass="secondary-button" />

                                    <Button text="Deactivate"
                                            onAction="#handleDeactivateUser"
                                            styleClass="danger-button" />
                                </HBox>
                            </GridPane>

                            <TableView fx:id="userTable" prefHeight="420.0">
                                <columns>
                                    <TableColumn fx:id="userIdColumn" text="ID" prefWidth="60.0" />
                                    <TableColumn fx:id="userFullNameColumn" text="Full Name" prefWidth="250.0" />
                                    <TableColumn fx:id="userUsernameColumn" text="Username" prefWidth="170.0" />
                                    <TableColumn fx:id="userRoleColumn" text="Role" prefWidth="140.0" />
                                    <TableColumn fx:id="userActiveColumn" text="Status" prefWidth="140.0" />
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <!-- =========================
                 ATTENDANCE TAB
                 ========================= -->
            <Tab text="Attendance">
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <content>
                        <VBox spacing="20.0" styleClass="page-container">
                            <padding>
                                <Insets top="24.0" right="28.0" bottom="28.0" left="28.0" />
                            </padding>

                            <VBox spacing="6.0">
                                <Label text="Attendance Register"
                                       styleClass="page-title" />

                                <Label text="Load a course register, mark student attendance, and save the records."
                                       styleClass="page-subtitle" />
                            </VBox>

                            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="form-card">
                                <padding>
                                    <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                                </padding>

                                <Label text="Course:" />
                                <ComboBox fx:id="attendanceCourseComboBox"
                                          promptText="Select course"
                                          prefWidth="330.0" />

                                <Label text="Date:" />
                                <DatePicker fx:id="attendanceDatePicker"
                                            prefWidth="160.0" />

                                <Button text="Load Register"
                                        onAction="#handleLoadRegister"
                                        styleClass="primary-button" />

                                <Button text="Save Attendance"
                                        onAction="#handleSaveAttendance"
                                        styleClass="secondary-button" />
                            </HBox>

                            <TableView fx:id="attendanceTable" prefHeight="460.0">
                                <columns>
                                    <TableColumn fx:id="attendanceStudentNumberColumn"
                                                 text="Student No."
                                                 prefWidth="160.0" />

                                    <TableColumn fx:id="attendanceStudentNameColumn"
                                                 text="Student Name"
                                                 prefWidth="300.0" />

                                    <TableColumn fx:id="attendanceStatusColumn"
                                                 text="Status"
                                                 prefWidth="180.0" />
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

            <!-- =========================
                 REPORTS TAB
                 ========================= -->
            <Tab text="Reports">
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <content>
                        <VBox spacing="20.0" styleClass="page-container">
                            <padding>
                                <Insets top="24.0" right="28.0" bottom="28.0" left="28.0" />
                            </padding>

                            <VBox spacing="6.0">
                                <Label text="Attendance Reports"
                                       styleClass="page-title" />

                                <Label text="Filter attendance records by course, date, or attendance status, including audit details."
                                       styleClass="page-subtitle" />
                            </VBox>

                            <VBox spacing="14.0" styleClass="form-card">
                                <padding>
                                    <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                                </padding>

                                <HBox alignment="CENTER_LEFT" spacing="12.0">
                                    <Label text="Course:" />
                                    <ComboBox fx:id="reportCourseComboBox"
                                              promptText="All courses"
                                              prefWidth="300.0" />

                                    <Label text="Date:" />
                                    <DatePicker fx:id="reportDatePicker"
                                                prefWidth="160.0" />

                                    <Label text="Status:" />
                                    <ComboBox fx:id="reportStatusComboBox"
                                              promptText="All statuses"
                                              prefWidth="150.0" />
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <Button text="Run Report"
                                            onAction="#handleRunReport"
                                            styleClass="primary-button" />

                                    <Button text="Clear Filters"
                                            onAction="#handleClearReportFilters"
                                            styleClass="secondary-button" />

                                    <Button text="Export CSV"
                                            onAction="#handleExportReport"
                                            styleClass="secondary-button" />

                                    <Region HBox.hgrow="ALWAYS" />

                                    <Label fx:id="reportCountLabel"
                                           text="0 record(s)"
                                           styleClass="report-summary" />

                                    <Label fx:id="reportAttendanceRateLabel"
                                           text="Attendance rate: 0.0%"
                                           styleClass="report-summary" />
                                </HBox>
                            </VBox>

                            <TableView fx:id="reportTable" prefHeight="440.0">
                                <columns>
                                    <TableColumn fx:id="reportCourseColumn"
                                                 text="Course"
                                                 prefWidth="130.0" />

                                    <TableColumn fx:id="reportStudentNumberColumn"
                                                 text="Student No."
                                                 prefWidth="140.0" />

                                    <TableColumn fx:id="reportStudentNameColumn"
                                                 text="Student Name"
                                                 prefWidth="240.0" />

                                    <TableColumn fx:id="reportDateColumn"
                                                 text="Date"
                                                 prefWidth="120.0" />

                                    <TableColumn fx:id="reportStatusColumn"
                                                 text="Status"
                                                 prefWidth="120.0" />

                                    <TableColumn fx:id="reportMarkedByColumn"
                                                 text="Marked By"
                                                 prefWidth="140.0" />

                                    <TableColumn fx:id="reportMarkedAtColumn"
                                                 text="Marked At"
                                                 prefWidth="170.0" />
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </ScrollPane>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
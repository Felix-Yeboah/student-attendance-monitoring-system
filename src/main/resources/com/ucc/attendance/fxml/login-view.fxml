<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ucc.attendance.controller.LoginController"
            styleClass="login-root">

    <center>
        <VBox alignment="CENTER" spacing="12.0" styleClass="login-card">
            <padding>
                <Insets top="26.0" right="30.0" bottom="26.0" left="30.0" />
            </padding>

            <Label text="SAM" styleClass="login-logo" />
            <Label text="Student Attendance Monitoring System"
                   styleClass="login-title"
                   wrapText="true" />

            <Label text="Secure access for attendance management"
                   styleClass="login-subtitle"
                   wrapText="true" />

            <VBox fx:id="loginFormBox" alignment="CENTER" spacing="11.0">
                <TextField fx:id="usernameField"
                           promptText="Username"
                           maxWidth="310.0" />

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               maxWidth="310.0" />

                <Button text="Sign In"
                        maxWidth="310.0"
                        styleClass="primary-button, login-main-button"
                        onAction="#handleLogin" />

                <Button text="Reset password"
                        styleClass="link-button"
                        onAction="#showResetForm" />

                <Label fx:id="loginMessageLabel"
                       text=""
                       styleClass="login-message"
                       wrapText="true"
                       maxWidth="310.0" />

                <Label text="Demo: admin / Admin@2026 or lecturer / Lecturer@2026"
                       styleClass="login-hint"
                       wrapText="true"
                       maxWidth="310.0" />
            </VBox>

            <VBox fx:id="resetPasswordBox"
                  alignment="CENTER"
                  spacing="10.0"
                  visible="false"
                  managed="false">

                <Label text="Reset Password" styleClass="reset-title" />

                <TextField fx:id="resetUsernameField"
                           promptText="Username"
                           maxWidth="310.0" />

                <PasswordField fx:id="currentPasswordField"
                               promptText="Current password"
                               maxWidth="310.0" />

                <PasswordField fx:id="newPasswordField"
                               promptText="New password"
                               maxWidth="310.0" />

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm new password"
                               maxWidth="310.0" />

                <HBox alignment="CENTER" spacing="10.0">
                    <Button text="Update Password"
                            styleClass="primary-button"
                            onAction="#handlePasswordReset" />

                    <Button text="Back"
                            styleClass="secondary-button"
                            onAction="#showLoginForm" />
                </HBox>

                <Label fx:id="resetMessageLabel"
                       text=""
                       styleClass="login-message"
                       wrapText="true"
                       maxWidth="310.0" />
            </VBox>
        </VBox>
    </center>
</BorderPane>
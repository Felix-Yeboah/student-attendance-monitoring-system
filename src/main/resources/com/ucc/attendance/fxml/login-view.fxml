<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ucc.attendance.controller.LoginController"
            styleClass="login-root">

    <center>
        <VBox alignment="CENTER" spacing="18.0" styleClass="login-card">
            <padding>
                <Insets top="36.0" right="42.0" bottom="36.0" left="42.0" />
            </padding>

            <Label text="Student Attendance Monitoring System"
                   styleClass="login-title"
                   wrapText="true" />

            <Label text="Sign in to continue"
                   styleClass="login-subtitle" />

            <TextField fx:id="usernameField"
                       promptText="Username"
                       maxWidth="340.0" />

            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           maxWidth="340.0" />

            <Button text="Login"
                    maxWidth="340.0"
                    styleClass="primary-button"
                    onAction="#handleLogin" />

            <Label fx:id="loginMessageLabel"
                   text=""
                   styleClass="login-message"
                   wrapText="true" />

            <Label text="Demo accounts: admin / Admin@2026, lecturer / Lecturer@2026"
                   styleClass="login-hint"
                   wrapText="true" />
        </VBox>
    </center>
</BorderPane>
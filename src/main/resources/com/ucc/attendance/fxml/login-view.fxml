<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ucc.attendance.controller.LoginController"
            styleClass="login-root">

    <center>
        <VBox alignment="CENTER"
              spacing="7.0"
              prefWidth="340.0"
              prefHeight="330.0"
              maxWidth="340.0"
              maxHeight="330.0"
              styleClass="login-card">

            <padding>
                <Insets top="16.0" right="22.0" bottom="16.0" left="22.0" />
            </padding>

            <Label text="SAM" styleClass="login-logo" />

            <Label text="Student Attendance Monitoring System"
                   styleClass="login-title"
                   wrapText="true"
                   maxWidth="285.0" />

            <Label text="Secure attendance access"
                   styleClass="login-subtitle" />

            <VBox fx:id="loginFormBox" alignment="CENTER" spacing="7.0">
                <TextField fx:id="usernameField"
                           promptText="Username"
                           maxWidth="275.0" />

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               maxWidth="275.0" />

                <Button text="Sign In"
                        maxWidth="275.0"
                        styleClass="primary-button, login-main-button"
                        onAction="#handleLogin" />

                <Button text="Reset password"
                        styleClass="link-button"
                        onAction="#showResetForm" />

                <Label fx:id="loginMessageLabel"
                       text=""
                       styleClass="login-message"
                       wrapText="true"
                       maxWidth="275.0" />
            </VBox>

            <VBox fx:id="resetPasswordBox"
                  alignment="CENTER"
                  spacing="6.0"
                  visible="false"
                  managed="false">

                <Label text="Reset Password" styleClass="reset-title" />

                <TextField fx:id="resetUsernameField"
                           promptText="Username"
                           maxWidth="275.0" />

                <PasswordField fx:id="currentPasswordField"
                               promptText="Current password"
                               maxWidth="275.0" />

                <PasswordField fx:id="newPasswordField"
                               promptText="New password"
                               maxWidth="275.0" />

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm new password"
                               maxWidth="275.0" />

                <HBox alignment="CENTER" spacing="8.0">
                    <Button text="Update"
                            styleClass="primary-button"
                            onAction="#handlePasswordReset" />

                    <Button text="Back"
                            styleClass="secondary-button"
                            onAction="#showLoginForm" />
                </HBox>

                <Label fx:id="resetMessageLabel"
                       text=""
                       styleClass="login-message"
                       wrapText="true"
                       maxWidth="275.0" />
            </VBox>
        </VBox>
    </center>
</BorderPane>